<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0 https://raw.githubusercontent.com/spotbugs/spotbugs/4.8.6/spotbugs/etc/findbugsfilter.xsd">

    <Match><Bug pattern="PA_PUBLIC_PRIMITIVE_ATTRIBUTE" /></Match>
    <Match><Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2" /></Match>
    <Match><Bug pattern="URF_UNREAD_FIELD,URF_UNREAD_PUBLIC_OR_PROTECTED_FIELD" /></Match>
    <Match><Bug pattern="CT_CONSTRUCTOR_THROW" /></Match>
</FindBugsFilter>
